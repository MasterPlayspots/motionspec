# MotionSpec — Stufe-A-Routing (nur fuer `motion route`/`pipeline` ohne --mock).
# Jeder OpenAI-kompatible Endpunkt. compile/demo/MCP brauchen KEINEN Key.

# Pflicht fuer Live-Routing:
MOTION_API_KEY=

# Optional (Defaults):
# MOTION_MODEL=anthropic/claude-haiku-4.5
# MOTION_BASE_URL=https://openrouter.ai/api/v1

# Alternativ wird OPENROUTER_API_KEY akzeptiert, wenn MOTION_API_KEY fehlt.
# OPENROUTER_API_KEY=

