{
  "name": "hoverLift",
  "version": "1.0.0",
  "purpose": "Hover micro-interaction — the element lifts slightly on hover (translateY upward; transform only).",
  "output": "css",
  "engine": "native-css",
  "paramSchema": {
    "distance": { "type": "string", "default": "6px", "pattern": "^[0-9]*\\.?[0-9]+(px|rem|em)$" },
    "duration": { "type": "number", "default": 0.2, "min": 0.05, "max": 1 }
  },
  "triggerDefaults": {},
  "performance": { "verified": true, "lcpSafe": true, "cost": 1, "verifiedAt": "2026-07-04" },
  "a11y": { "reducedMotionFallback": "static" },
  "template": "{{css target}} { transition: transform {{css params.duration}}s cubic-bezier(0.22, 0.61, 0.36, 1); }\n{{css target}}:hover { transform: translateY(-{{css params.distance}}); }",
  "demo": { "html": "<div class=\"d-hoverLift\" style=\"display:inline-flex;align-items:center;justify-content:center;width:8rem;height:5rem;border-radius:14px;background:var(--surface);border:1px solid var(--line);cursor:pointer\">Hover — lift</div>", "params": { "distance": "8px", "duration": 0.2 } }
}
